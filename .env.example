# ─────────────────────────────────────────────────────────────────
# MagicClean — Variables de entorno
# Copia este archivo como .env.local y llena los valores reales.
# NUNCA subas .env.local a GitHub.
# ─────────────────────────────────────────────────────────────────

# SUPABASE
# Obtén estos valores en: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# RESEND
# Obtén tu API key en: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# EMAIL DE NOTIFICACIÓN INTERNA
# Correo donde el equipo MagicClean recibe el aviso de cada nuevo lead
NOTIFY_EMAIL=hola@magiclean.mx

# DOMINIO DEL SITIO
# URL canónica del sitio en producción (sin trailing slash).
# OBLIGATORIO configurar en Vercel cuando se conecte el dominio final.
# Mientras no se configure, se usa https://magiclean-web.vercel.app como fallback
# y el warning aparece en los logs de build.
NEXT_PUBLIC_SITE_URL=https://magiclean.mx

# WORDPRESS (OPCIONAL)
# Endpoint GraphQL del WordPress headless (plugin WPGraphQL).
# Si NO se configura, la landing usa los textos por defecto hardcoded —
# la integración con WP queda silenciosamente inactiva.
# Configura sólo cuando quieras que el contenido se gestione desde WP.
WP_GRAPHQL_URL=https://cms.magiclean.mx/graphql
