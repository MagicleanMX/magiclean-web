# ─────────────────────────────────────────────────────────────────
# MagicClean — Variables de entorno
# Copia este archivo como .env.local y llena los valores reales.
# NUNCA subas .env.local a GitHub.
# ─────────────────────────────────────────────────────────────────

# SUPABASE
# Obtén estos valores en: https://supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# RESEND
# Obtén tu API key en: https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# EMAIL DE NOTIFICACIÓN INTERNA
# Correo donde el equipo MagicClean recibe el aviso de cada nuevo lead
NOTIFY_EMAIL=hola@magiclean.mx

# DOMINIO DEL SITIO
# URL canónica del sitio (sin trailing slash).
#
# ────────── DÓNDE CONFIGURAR ──────────
# Local dev     : en .env.local → http://localhost:3006 (para silenciar el
#                 warning de build "NEXT_PUBLIC_SITE_URL not set in production")
# Vercel prod   : en Vercel dashboard → Settings → Environment Variables →
#                 Production → NEXT_PUBLIC_SITE_URL = https://magiclean.mx
# Vercel preview: opcional, por default Vercel inyecta VERCEL_URL y el fallback
#                 del código usa *.vercel.app si no se setea.
# ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://magiclean.mx

# SENTRY DSN (OPCIONAL)
# Si se configura, reemplaza el DSN hardcoded en sentry.server.config.ts /
# sentry.edge.config.ts / instrumentation-client.ts. Útil para enviar errores
# de preview/staging a un project Sentry distinto que el de producción.
# DSNs de Sentry son públicos (client-side), por eso es NEXT_PUBLIC_*.
# Si no se configura, se usa el DSN por defecto del código.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxx@oXXXXXXX.ingest.us.sentry.io/XXXXXXX

# WORDPRESS (OPCIONAL)
# Endpoint GraphQL del WordPress headless (plugin WPGraphQL).
# Si NO se configura, la landing usa los textos por defecto hardcoded —
# la integración con WP queda silenciosamente inactiva.
# Configura sólo cuando quieras que el contenido se gestione desde WP.
WP_GRAPHQL_URL=https://cms.magiclean.mx/graphql
